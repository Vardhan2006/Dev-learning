{
  "compilerOptions": {
    /* Target & Environment */
    "target": "ESNext",                          /* Latest ECMAScript features */
    "module": "NodeNext",                        /* Standard for modern Node.js module resolution */
    "moduleResolution": "NodeNext",              /* Ensures modules match Node.js behavior */
    "lib": ["ESNext"],                           /* Includes type definitions for latest JS */

    /* Directories */
    "rootDir": "./src",                          /* Locate your typescript source files */
    "outDir": "./dist",                          /* Destination for compiled JavaScript files */

    /* Strictness & Quality */
    "strict": true,                              /* Enables strict type-checking options */
    "noImplicitAny": true,                       /* Raise error on expressions and declarations with an implied 'any' type */
    "strictNullChecks": true,                    /* Ensures null/undefined are handled correctly */
    "forceConsistentCasingInFileNames": true,    /* Disallows inconsistently-cased references to the same file */

    /* Interoperability */
    "esModuleInterop": true,                     /* Enables emit interoperability between CommonJS and ES Modules */
    "skipLibCheck": true,                        /* Skip type checking of declaration files (.d.ts) */
    "types": ["node"]
  },
  "include": ["src/**/*"],                       /* Only compile files inside the src directory */
  "exclude": ["node_modules", "dist"]            /* Files or folders to ignore during compilation */
}
